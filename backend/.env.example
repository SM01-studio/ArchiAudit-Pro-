# ArchiAudit Backend Environment Configuration Template
# Copy this file to .env and fill in your values

# Development mode (set to 'true' for local testing, 'false' for production)
DEV_MODE=true

# Main Portal API (for token verification)
MAIN_PORTAL_API=https://api.siliang.cfd

# Gemini API via LinkAPI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_ENDPOINT=https://api.linkapi.ai/v1/chat/completions

# Text/Vision model (for floor plan analysis and prompt generation)
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview

# Image generation model (for image-to-image optimization)
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Server Port
PORT=5003
